# udev rules for USB printer hotplug detection
# These rules trigger actions when USB printers are connected/disconnected

# Rule for USB printer connection - trigger CUPS reload
# This works for most USB printers identified by bInterfaceClass=7 (printer)
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="07", ACTION=="add", \
    RUN+="/bin/systemctl restart cups.service", \
    RUN+="/usr/bin/logger -t printer-hotplug 'USB printer connected, restarting CUPS'"

# Rule for USB printer disconnection - regenerate Avahi services to remove stale entries
SUBSYSTEM=="usb", ACTION=="remove", ENV{ID_USB_INTERFACES}=="*:070102:*", \
    RUN+="/usr/bin/logger -t printer-hotplug 'USB printer disconnected'", \
    RUN+="/bin/bash -c 'sleep 5 && /opt/printserver/scripts/configure-avahi.sh &'"

# Brother specific rules (common Brother USB vendor ID: 04f9)
SUBSYSTEM=="usb", ATTR{idVendor}=="04f9", ACTION=="add", \
    RUN+="/bin/systemctl restart cups.service", \
    RUN+="/usr/bin/logger -t printer-hotplug 'Brother printer connected'"

# HP specific rules (HP USB vendor ID: 03f0)
SUBSYSTEM=="usb", ATTR{idVendor}=="03f0", ACTION=="add", \
    RUN+="/bin/systemctl restart cups.service", \
    RUN+="/usr/bin/logger -t printer-hotplug 'HP printer connected'"

# Canon specific rules (Canon USB vendor ID: 04a9)
SUBSYSTEM=="usb", ATTR{idVendor}=="04a9", ACTION=="add", \
    RUN+="/bin/systemctl restart cups.service", \
    RUN+="/usr/bin/logger -t printer-hotplug 'Canon printer connected'"

# Epson specific rules (Epson USB vendor ID: 04b8)
SUBSYSTEM=="usb", ATTR{idVendor}=="04b8", ACTION=="add", \
    RUN+="/bin/systemctl restart cups.service", \
    RUN+="/usr/bin/logger -t printer-hotplug 'Epson printer connected'"

# Generic USB printer - fallback rule using usblp module
KERNEL=="lp[0-9]*", SUBSYSTEM=="usb", ACTION=="add", \
    RUN+="/bin/systemctl restart cups.service"

# Set proper permissions for printer devices
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="07", MODE="0666"

# Trigger Avahi to regenerate AirPrint services when printer is added
# Delay gives CUPS time to restart and register the new printer
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="07", ACTION=="add", \
    RUN+="/bin/bash -c 'sleep 10 && /opt/printserver/scripts/configure-avahi.sh &'"
