# udev rules for USB printer hotplug
# /etc/udev/rules.d/99-printer.rules
#
# On connect:  hotplug-printer.sh add
#   → restarts CUPS, waits for the scheduler, auto-adds the printer queue,
#     enables job acceptance, marks as shared, then refreshes Avahi (mDNS).
#   → Windows 10/11, iOS and Android discover the printer automatically once
#     Avahi broadcasts the IPP/dnssd record.
#
# On disconnect: hotplug-printer.sh remove
#   → CUPS queue is preserved so queued jobs survive a cable reconnect.
#     Avahi is refreshed to remove stale mDNS advertisements.

# Restart CUPS immediately so it can re-enumerate the USB device tree.
# hotplug-printer.sh then waits for the scheduler before doing lpadmin work.
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="07", ACTION=="add", \
    RUN+="/bin/systemctl restart cups.service"

# Disable USB autosuspend for printers — prevents kernel-side sleep latency
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="07", ACTION=="add", \
    TEST=="power/autosuspend", ATTR{power/autosuspend}="-1"
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="07", ACTION=="add", \
    TEST=="power/control", ATTR{power/control}="on"

# Run the full hotplug pipeline asynchronously (needs a live CUPS scheduler).
# After hotplug completes, also wake the printer from firmware sleep so it's
# ready for jobs immediately (the printer may have been power-cycled or
# reconnected while in its own internal sleep mode).
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="07", ACTION=="add", \
    RUN+="/bin/bash -c 'sleep 3 && /opt/printserver/scripts/hotplug-printer.sh add >> /var/log/printer-hotplug.log 2>&1 && /opt/printserver/scripts/wake-printer.sh >> /var/log/printer-hotplug.log 2>&1 &'"

# USB printer disconnect — ID_USB_INTERFACES survives after the class attr is gone.
SUBSYSTEM=="usb", ENV{ID_USB_INTERFACES}=="*:070102:*", ACTION=="remove", \
    RUN+="/bin/bash -c 'sleep 5 && /opt/printserver/scripts/hotplug-printer.sh remove >> /var/log/printer-hotplug.log 2>&1 &'"

# Set read/write permissions on the raw USB device node for lp tools.
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="07", MODE="0666"
